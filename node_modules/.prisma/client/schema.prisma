generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlateStatus {
  DRAFT
  ACTIVE
  PAUSED
  FINISHED
}

model User {
  id         String        @id @default(cuid())
  discordId  String        @unique
  username   String
  globalName String?
  avatar     String?
  isAdmin    Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  votes      Vote[]
  sessions   UserSession[]
}

model Plate {
  id            String      @id @default(cuid())
  title         String
  description   String?
  coverImageUrl String?
  startsAt      DateTime?
  endsAt        DateTime?
  status        PlateStatus @default(DRAFT)
  maxVotesPerIp Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  nominees      Nominee[]
  votes         Vote[]
}

model Nominee {
  id          String   @id @default(cuid())
  plateId     String
  displayName String
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plate       Plate    @relation(fields: [plateId], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@index([plateId])
}

model Vote {
  id          String   @id @default(cuid())
  plateId     String
  nomineeId   String
  userId      String
  voterIpHash String
  userAgent   String?
  createdAt   DateTime @default(now())
  plate       Plate    @relation(fields: [plateId], references: [id], onDelete: Cascade)
  nominee     Nominee  @relation(fields: [nomineeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([plateId, userId])
  @@index([plateId, voterIpHash])
  @@index([nomineeId])
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  ipHash     String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ipHash])
}

model ParticipantCatalog {
  id          String   @id @default(cuid())
  displayName String
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
